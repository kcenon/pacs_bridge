{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "pacs-bridge",
  "version": "0.2.0",
  "description": "HL7-DICOM Bridge for Healthcare Integration",
  "homepage": "https://github.com/kcenon/pacs_bridge",
  "license": "BSD-3-Clause",
  "supports": "!(uwp | arm | wasm32)",
  "dependencies": [
    "fmt",
    "spdlog",
    {
      "name": "openssl",
      "platform": "!windows"
    },
    {
      "name": "gtest",
      "version>=": "1.14.0"
    },
    {
      "name": "nlohmann-json",
      "version>=": "3.11.0"
    },
    {
      "name": "yaml-cpp",
      "version>=": "0.8.0"
    }
  ],
  "features": {
    "tests": {
      "description": "Build with test dependencies",
      "dependencies": [
        "gtest"
      ]
    },
    "tls": {
      "description": "Enable TLS support",
      "dependencies": [
        "openssl"
      ]
    }
  },
  "overrides": [
    { "name": "gtest", "version": "1.17.0" },
    { "name": "benchmark", "version": "1.9.5" },
    { "name": "spdlog", "version": "1.15.3" },
    { "name": "openssl", "version": "3.4.1" }
  ]
}
